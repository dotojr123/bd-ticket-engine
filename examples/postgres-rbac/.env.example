# URL de conexão do PostgreSQL para extração e runtime (DB_DRIVER=postgres)
DATABASE_URL=postgres://user:password@localhost:5432/meu_banco

# Driver de banco usado em runtime pelas rotas geradas: "postgres" ou "sqlite" (default: sqlite)
DB_DRIVER=sqlite

# Caminho do arquivo SQLite local usado em runtime quando DB_DRIVER=sqlite (default: local.db)
SQLITE_PATH=local.db

# Chave secreta usada para verificar a assinatura dos JWTs recebidos nas rotas geradas.
# Obrigatória em qualquer ambiente que sirva tráfego real — gere uma chave forte e não a reutilize
# entre ambientes (dev/staging/prod).
JWT_SECRET=troque-por-uma-chave-secreta-forte-e-unica

# Nome do projeto gravado no metadata.json gerado
PROJECT_NAME=BD-Ticket

# Fallback para Cloudflare D1 se wrangler.toml não existir
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_API_TOKEN=
