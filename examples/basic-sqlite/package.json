{
  "name": "bd-ticket-example-basic-sqlite",
  "version": "1.0.0",
  "private": true,
  "description": "Exemplo mínimo executável do BD-Ticket Engine: SQLite -> metadata -> codegen -> servidor Hono com CRUD real.",
  "type": "commonjs",
  "scripts": {
    "seed": "tsx seed.ts",
    "db:extract-metadata": "tsx src/bin/extractor.ts --driver sqlite",
    "db:codegen": "tsx src/bin/codegen.ts",
    "db:validate": "tsx src/bin/validator.ts",
    "setup": "npm run seed && npm run db:extract-metadata && npm run db:codegen && npm run db:validate",
    "dev": "tsx server.ts",
    "token": "tsx mint-token.ts",
    "db:migrate": "tsx src/bin/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.9.0",
    "@tanstack/react-query": "^5.101.3",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.31",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.5.4"
  }
}